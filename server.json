{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.wearehoust/front-mcp",
  "title": "Front MCP",
  "description": "MCP server for Front: conversations, contacts, messages, tags, and inbox workflows.",
  "repository": {
    "url": "https://github.com/wearehoust/front-mcp",
    "source": "github"
  },
  "version": "1.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@houst-com/front-mcp",
      "version": "1.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "FRONT_API_TOKEN",
          "description": "Front API token for authentication",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
