{
  "name": "front-mcp-server",
  "version": "1.0.0",
  "description": "Secure, fully-featured MCP server for the Front Platform API — 26 tools, 200+ actions, OAuth support, configurable policy engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "front-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run type-check && npm run test && npm run build"
  },
  "keywords": [
    "mcp",
    "front",
    "frontapp",
    "model-context-protocol",
    "llm",
    "claude",
    "customer-communication"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/node": "22.15.2",
    "@vitest/coverage-v8": "3.1.1",
    "eslint": "10.1.0",
    "msw": "2.7.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.58.0",
    "vitest": "3.1.1"
  }
}
