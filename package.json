{
  "name": "@houst-com/front-mcp",
  "version": "1.1.0",
  "description": "Secure, fully-featured MCP server for the Front Platform API — 26 tools, 200+ actions, OAuth support, configurable policy engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "front-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/postbuild.js",
    "smoke": "node scripts/smoke.js",
    "lint": "eslint 'src/**/*.ts'",
    "type-check": "node --max-old-space-size=8192 ./node_modules/.bin/tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate-docs": "node scripts/generate-tool-docs.js",
    "prepublishOnly": "npm run lint && npm run type-check && npm run test && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "front",
    "front-api",
    "frontapp",
    "ai-agents",
    "automation",
    "customer-support",
    "inbox-automation",
    "llm",
    "claude",
    "typescript"
  ],
  "homepage": "https://github.com/wearehoust/front-mcp#readme",
  "bugs": {
    "url": "https://github.com/wearehoust/front-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wearehoust/front-mcp.git"
  },
  "author": "Houst (https://houst.com)",
  "license": "MIT",
  "mcpName": "io.github.wearehoust/front-mcp",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/node": "22.15.2",
    "@vitest/coverage-v8": "3.1.1",
    "eslint": "10.1.0",
    "msw": "2.7.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.58.0",
    "vitest": "3.1.1"
  }
}
