# Front MCP Server Environment Variables
# Copy this file to .env and fill in your values

# Authentication (choose one method)
# Option 1: API Token (quick setup)
FRONT_API_TOKEN=

# Option 2: OAuth (recommended for production)
# FRONT_MCP_AUTH_METHOD=oauth
# FRONT_MCP_OAUTH_SECRET=

# Server Configuration
# FRONT_MCP_LOG_LEVEL=info          # error, warn, info, debug
# FRONT_MCP_POLICY_FILE=            # path to custom policy.json
